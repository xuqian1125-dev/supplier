# 数据库（开发用 sqlite，生产切 postgres）
DATABASE_URL=sqlite:///./supplier.db
# 生产示例：DATABASE_URL=postgresql+psycopg://supplier:supplier@localhost:5432/supplier

# 单用户鉴权
AUTH_USERNAME=admin
AUTH_PASSWORD=please-change-me
JWT_SECRET=run-openssl-rand-hex-32-to-generate
JWT_EXPIRES_HOURS=24

# Claude API
ANTHROPIC_API_KEY=sk-ant-xxx
CLAUDE_MODEL=claude-haiku-4-5-20251001

# 对象存储（开发可用 local；生产建议 r2/s3/oss）
STORAGE_PROVIDER=local
LOCAL_STORAGE_DIR=./uploads
# 生产示例：
# STORAGE_PROVIDER=r2
# STORAGE_BUCKET=supplier-files
# STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# STORAGE_ACCESS_KEY=xxx
# STORAGE_SECRET_KEY=xxx
# STORAGE_PUBLIC_BASE_URL=https://files.example.com

# 汇率源
FX_API_BASE=https://api.frankfurter.app

# CORS
FRONTEND_ORIGIN=http://localhost:3000
